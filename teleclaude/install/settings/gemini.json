{
  "tools": {
    "allowed": [ "*" ],
    "enableHooks": true,
    "sandbox": false
  },
  "skills": {
    "enabled": true
  },
  "context": {
    "fileName": [
      "AGENTS.md",
      "GEMINI.md"
    ],
    "includeDirectories": [
      "/"
    ],
    "fileFiltering": {
      "respectGitIgnore": false
    }
  },
  "general": {
    "checkpointing": {
      "enabled": true
    },
    "previewFeatures": true,
    "disableAutoUpdate": false,
    "enableAutoUpdate": true,
    "sessionRetention": {
      "warningAcknowledged": true,
      "enabled": true,
      "maxAge": "120d"
    }
  },
  "experimental": {
    "useOSC52Paste": true,
    "skills": true,
    "introspectionAgentSettings": {
      "enabled": true
    },
    "plan": true
  }
}
