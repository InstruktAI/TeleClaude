/MUSICIANS/B/Bjerregaard_Johannes/

# from Warren: all 20 sound effects added, clean re-rip from original tape.
/update/fix/MUSICIANS/H/Hubbard_Rob/Flash_Gordon.sid
/MUSICIANS/H/Hubbard_Rob/

# from Prof. Chaos and Wilfred : One more subtune selectable. Init fixed,
#      y-register was undefined, which could break songs in many ways.
/update/fix/MUSICIANS/H/Hubbard_Rob/Trans-Atlantic_Balloon_Challenge.sid
/MUSICIANS/H/Hubbard_Rob/

# from iAN CooG: Reripped, it lacked a couple of bytes at end of data.
/update/fix/MUSICIANS/P/Page_Jason/Albino_4.sid
/MUSICIANS/P/Page_Jason/

# from Professor Chaos: fixed original out-of-sync upon loop
/update/fix/MUSICIANS/T/TCC/Must_ve_Been.sid
/MUSICIANS/T/TCC/

# from Wilfred: Re-ripped to make the tune loop correctly.
/update/fix/MUSICIANS/T/Tel_Jeroen/Earthquake.sid
/MUSICIANS/T/Tel_Jeroen/

