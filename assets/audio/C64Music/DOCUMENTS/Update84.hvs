#                Thanks to bytespiller for reporting.
/update/fix/MUSICIANS/T/Tel_Jeroen/Pal_sine_hoener_tune_1.sid
/MUSICIANS/T/Tel_Jeroen/

# from Trident?: Fixed to play at 5x as intended (anonymous upload at DeepSid)
/update/fix/MUSICIANS/T/Trident/Little_Birdie.sid
/MUSICIANS/T/Trident/

# from iAN CooG: Reripped, wrong end tune pointer made it loop earlier.
#                Thanks to Denny Müller for reporting.
#                (https://csdb.dk/release/?id=93367)
/update/fix/MUSICIANS/Y/Yulk/Round_Midnight.sid
/MUSICIANS/Y/Yulk/

